{
  "name": "coolstory-plugin",
  "version": "0.1.0",
  "description": "Public CoolStory agent and CLI integration plugin.",
  "type": "module",
  "bin": {
    "coolstory-desktop": "src/index.js",
    "coolstory-plugin": "src/index.js",
    "coolstory": "src/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "src",
    "coolstory.plugin.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "smoke": "node src/index.js --help",
    "build:bundle": "esbuild src/index.js --bundle --platform=node --format=cjs --outfile=dist/sea-entry.cjs",
    "build:binary": "npm run build:bundle && node scripts/build-sea.mjs",
    "build:binaries": "npm run build:binary"
  },
  "keywords": [
    "coolstory",
    "agent",
    "plugin",
    "cli",
    "git",
    "prd"
  ],
  "license": "MIT",
  "devDependencies": {
    "esbuild": "^0.27.0",
    "postject": "^1.0.0-alpha.6"
  }
}
