{
  "name": "coolstory-plugin",
  "version": "0.1.0",
  "description": "Public CoolStory agent and CLI integration plugin.",
  "type": "module",
  "bin": {
    "coolstory-plugin": "src/index.js",
    "coolstory": "src/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "src",
    "coolstory.plugin.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "smoke": "node src/index.js --help",
    "build:binary": "pkg . --out-path dist",
    "build:binaries": "npm run build:binary -- --targets node18-linux-x64"
  },
  "pkg": {
    "scripts": [
      "src/**/*.js"
    ],
    "assets": [
      "coolstory.plugin.json",
      "README.md",
      "docs/**/*.md"
    ],
    "outputPath": "dist"
  },
  "keywords": [
    "coolstory",
    "agent",
    "plugin",
    "cli",
    "git",
    "prd"
  ],
  "license": "MIT",
  "devDependencies": {
    "@yao-pkg/pkg": "^6.7.1"
  }
}
